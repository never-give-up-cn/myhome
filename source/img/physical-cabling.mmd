    ONT --> FW_P1
    FW_P2 --> SR_ETH3
    FW_P3 --> SR_ETH0
    FW_P4 --> ROUTER
    FW_P5 --> R730XD
    FW_P6 --> NVR
    FW_P7 --> IOT

    classDef isp fill:#FFE4E1,stroke:#333
    classDef fw fill:#FFCCCC,stroke:#333
    classDef sr fill:#CCFFCC,stroke:#333
    classDef dev fill:#E8E8FF,stroke:#333
    classDef sw fill:#FFFFCC,stroke:#333

    class ONT isp
